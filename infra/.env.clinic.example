# =============================================================================
# foreverhuman.health — Variabile Clinică
# Copiază în .env și completează înainte de `docker compose up`
# NICIODATĂ nu comite .env în git!
# =============================================================================

# Identificator unic clinică (UUID generat la setup)
CLINIC_ID=00000000-0000-0000-0000-000000000000

# Domeniu clinică (ex: clinica-xyz.foreverhuman.health sau domeniu propriu)
DOMAIN=clinic.example.com

# Versiuni imagini
API_VERSION=latest
INFRA_AGENT_VERSION=latest

# Environment
ENVIRONMENT=production
LOG_LEVEL=info

# ---- PostgreSQL ----
POSTGRES_USER=foreverhuman
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=foreverhuman_clinic

# ---- Security ----
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING

# ---- LLM Provider ----
# Opțiuni: anthropic | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-XXXX

# Dacă LLM_PROVIDER=ollama (clinici fără internet stabil):
# OLLAMA_URL=http://ollama:11434

# ---- Embeddings ----
# Opțiuni: openai | ollama
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-XXXX

# ---- Senzori (opțional — completează ce ai) ----
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
ULTRAHUMAN_API_KEY=
YOUTUBE_API_KEY=

# ---- Admin ----
ADMIN_EMAIL=admin@example.com
